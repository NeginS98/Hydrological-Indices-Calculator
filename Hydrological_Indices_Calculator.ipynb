      "source": [
        "# **DEM**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "S1pQz8q4Jq1J",
        "outputId": "672cd764-d5a6-4a15-b77a-55fbbd195f72"
      },
      "outputs": [],
      "source": [
        "!wget \"https://prd-tnm.s3.amazonaws.com/StagedProducts/Elevation/1/TIFF/current/n38w081/USGS_1_n38w081.tif\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 14,
      "metadata": {
        "id": "EWggLTRWJrmd"
      },
      "outputs": [],
      "source": [
        "with rasterio.open(\"USGS_1_n38w081.tif\") as src:\n",
        "    dem = src.read(1)\n",
        "    transform = src.transform\n",
        "    crs = src.crs"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 15,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 699
        },
        "id": "sJgTKZUnKO8j",
        "outputId": "735fc0a6-5297-4924-f51e-68dff8b65e9d"
      },
      "outputs": [
        {
          "data": {
            "image/png": "",
            "text/plain": [
              "<Figure size 1000x800 with 2 Axes>"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ],
      "source": [
        "plt.figure(figsize=(10, 8))\n",
        "plt.imshow(dem, cmap=\"terrain\")\n",
        "plt.colorbar(label=\"Elevation (m)\")\n",
        "plt.title(\"DEM - West Virginia\")\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "RHjdyHdzy812"
      },
      "source": [
        "# **NDWI**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "OXvyAgQVy1IC"
      },
      "outputs": [],
      "source": [
        "image = ee.ImageCollection(\"LANDSAT/LC08/C02/T1_L2\") \\\n",
        "    .filterBounds(ee.Geometry.Rectangle(west_virginia.total_bounds.tolist())) \\\n",
        "    .filterDate(\"2024-06-01\", \"2024-09-01\") \\\n",
        "    .median()\n",
        "region = ee.Geometry.Rectangle(west_virginia.total_bounds.tolist())\n",
        "green = image.select(\"SR_B3\")\n",
        "nir   = image.select(\"SR_B5\")\n",
        "\n",
        "ndwi = green.subtract(nir).divide(green.add(nir)).rename(\"NDWI\")"
      ]
    },
