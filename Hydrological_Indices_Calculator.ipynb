      "source": [
        "wv_flood = county[county[\"GEOID\"].isin(flood_counties_wv.values())]\n",
        "fig, ax = plt.subplots(figsize=(8, 6))\n",
        "west_virginia.plot(ax=ax, color=\"lightgray\", edgecolor=\"black\", linewidth=0.5)\n",
        "wv_flood.plot(ax=ax, color=\"steelblue\", edgecolor=\"black\", linewidth=0.5)\n",
        "\n",
        "for idx, row in wv_flood.iterrows():\n",
        "    centroid = row.geometry.centroid\n",
        "    ax.annotate(\n",
        "        row[\"NAME\"],\n",
        "        xy=(centroid.x, centroid.y),\n",
        "        ha=\"center\",\n",
        "        fontsize=8,\n",
        "        color=\"black\"\n",
        "    )\n",
        "\n",
        "ax.set_title(\"West Virginia - Flood Prone Counties\", fontsize=14)\n",
        "plt.show()"
      ]
    },
